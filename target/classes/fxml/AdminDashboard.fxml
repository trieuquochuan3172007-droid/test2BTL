<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AdminDashboardController"
            prefWidth="1100" prefHeight="720"
            stylesheets="@../styles/app.css" styleClass="page-bg">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="main-header">
            <Label text="⚙ BẢNG ĐIỀU KHIỂN QUẢN TRỊ" styleClass="header-title" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblWelcome" text="Admin" styleClass="header-user"/>
            <Button text="Đăng xuất" onAction="#handleLogout" styleClass="btn-danger"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" styleClass="main-content">

            <!-- Thống kê nhanh -->
            <HBox spacing="12">
                <VBox prefWidth="200" styleClass="stat-card">
                    <Label text="Tổng phiên" styleClass="stat-title"/>
                    <Label fx:id="lblTotalSessions" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox prefWidth="200" styleClass="stat-card">
                    <Label text="Đang chạy" styleClass="stat-title"/>
                    <Label fx:id="lblRunning" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox prefWidth="200" styleClass="stat-card">
                    <Label text="Đã kết thúc" styleClass="stat-title"/>
                    <Label fx:id="lblFinished" text="0" styleClass="stat-value"/>
                </VBox>
            </HBox>

            <Label text="Quản lý tất cả phiên đấu giá" styleClass="section-title"/>

            <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" styleClass="auction-table">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn text="STT" prefWidth="50">
                        <cellValueFactory><PropertyValueFactory property="stt"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Mã phiên" prefWidth="180">
                        <cellValueFactory><PropertyValueFactory property="auctionId"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Sản phẩm" prefWidth="200">
                        <cellValueFactory><PropertyValueFactory property="itemName"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Giá hiện tại" prefWidth="150">
                        <cellValueFactory><PropertyValueFactory property="currentPrice"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Trạng thái" prefWidth="120">
                        <cellValueFactory><PropertyValueFactory property="status"/></cellValueFactory>
                    </TableColumn>
                </columns>
                <placeholder>
                    <Label text="Không có dữ liệu." styleClass="empty-hint"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="main-footer">
            <Button text="Đóng phiên đã chọn" onAction="#handleForceClose" styleClass="btn-danger"/>
            <Button text="Làm mới" onAction="#handleRefresh" styleClass="btn-secondary"/>
        </HBox>
    </bottom>
</BorderPane>
