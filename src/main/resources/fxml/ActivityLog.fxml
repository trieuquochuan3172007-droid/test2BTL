<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.ActivityLogController"
            stylesheets="@../styles/app.css" styleClass="page-bg"
            prefWidth="900" prefHeight="600">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="main-header">
            <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-secondary"/>
            <Label text="📋 Activity Log" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔄 Làm mới" onAction="#handleRefresh"
                    style="-fx-background-color: #1e3a5f; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 8;
                           -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <TableView fx:id="logTable" VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colUser"   text="User"      prefWidth="150"/>
                    <TableColumn fx:id="colAction" text="Action"    prefWidth="150"/>
                    <TableColumn fx:id="colDetail" text="Chi tiết"  prefWidth="350"/>
                    <TableColumn fx:id="colTime"   text="Thời gian" prefWidth="180"/>
                </columns>
                <placeholder>
                    <Label text="Chưa có log nào." style="-fx-text-fill: #94a3b8;"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>
</BorderPane>