<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="24" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.ProfileController"
      prefWidth="520" prefHeight="600"
      stylesheets="@../styles/app.css" styleClass="page-bg">
    <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Hồ sơ cá nhân" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </HBox>

    <!-- Avatar + tên -->
    <VBox alignment="CENTER" spacing="8">
        <Label fx:id="lblAvatar"
               style="-fx-background-color: #3b82f6; -fx-background-radius: 50;
                      -fx-min-width: 72; -fx-min-height: 72;
                      -fx-font-size: 28px; -fx-font-weight: bold;
                      -fx-text-fill: white; -fx-alignment: center;"/>
        <Label fx:id="lblUsername"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label fx:id="lblRole"
               style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;"/>
    </VBox>

    <!-- Thẻ ví tiền -->
    <VBox styleClass="stat-card" spacing="16">
        <Label text="💰 Ví tiền" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <HBox spacing="12">
            <!-- Số dư khả dụng -->
            <VBox HBox.hgrow="ALWAYS" spacing="4"
                  style="-fx-background-color: #0f2744; -fx-background-radius: 10; -fx-padding: 16;">
                <Label text="Số dư khả dụng"
                       style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                <Label fx:id="lblBalance"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
            </VBox>
            <!-- Tiền đang khóa -->
            <VBox HBox.hgrow="ALWAYS" spacing="4"
                  style="-fx-background-color: #0f2744; -fx-background-radius: 10; -fx-padding: 16;">
                <Label text="Đang khóa (bid)"
                       style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                <Label fx:id="lblFrozen"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
            </VBox>
        </HBox>

        <!-- Nạp tiền -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="txtDeposit" promptText="Nhập số tiền muốn nạp (VND)"
                       HBox.hgrow="ALWAYS" prefHeight="40" styleClass="text-input"/>
            <Button text="Nạp tiền" onAction="#handleDeposit"
                    prefHeight="40" styleClass="btn-join-auction"/>
        </HBox>
        <Label fx:id="lblDepositMsg" wrapText="true"
               style="-fx-font-size: 13px;"/>
    </VBox>

    <!-- Email -->
    <VBox styleClass="stat-card" spacing="8">
        <Label text="📧 Thông tin tài khoản"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <HBox spacing="8">
            <Label text="Email:"
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
            <Label fx:id="lblEmail"
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
        </HBox>
    </VBox>
    <!-- Phiên tôi đang tham gia -->
       <VBox styleClass="stat-card" spacing="10">
       <Label text="🏷️ Phiên tôi đang tham gia"
              style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
       <TableView fx:id="myBidsTable" prefHeight="200"
                     style="-fx-background-color: transparent;">
              <columnResizePolicy>
              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
              </columnResizePolicy>
              <columns>
              <TableColumn fx:id="colBidItem" text="Sản phẩm" prefWidth="180"/>
              <TableColumn fx:id="colBidAmount" text="Giá đã bid" prefWidth="130"/>
              <TableColumn fx:id="colBidStatus" text="Trạng thái" prefWidth="120"/>
              </columns>
              <placeholder>
              <Label text="Chưa tham gia phiên nào."
                     style="-fx-text-fill: #94a3b8;"/>
              </placeholder>
       </TableView>
       </VBox>
</VBox>